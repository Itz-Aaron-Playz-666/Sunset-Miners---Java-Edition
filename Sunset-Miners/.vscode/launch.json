    "version": "0.2.0",
    "configurations": [
        
        {
            "type": "java",
            "name": "Launch SunsetMiners",
            "request": "launch",
            "mainClass": "sunsetminers.desktopmodule.DesktopLauncher",
            "osx": {
                "vmArgs": "-XstartOnFirstThread -ea"
            },
            "vmArgs": "-ea"
        },
        
        
        {
            "type": "java",
            "name": "Launch SunsetMiners VR",
            "request": "launch",
            "mainClass": "sunsetminers.pcvr.VrLauncher",
            "osx": {
                "vmArgs": "-XstartOnFirstThread -ea"
            },
            "vmArgs": "-ea"
        },
        [/IF=JME_VR]

    ]
}
